{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "LARK_APP_ID",
    "LARK_APP_SECRET",
    "REDIRECT_URI",
    "DESKTOP_APP_URL",
    "MOBILE_APP_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_LARK_APP_ID",
    "LARK_DEBUG_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
